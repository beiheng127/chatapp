{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "ignoreDeprecations": "6.0",
     // 核心配置：包含自定义类型文件
    "typeRoots": [
      "./node_modules/@types",
    ]
  },
  "include": [
    "src/**/*", 
    "../frontend/src/routes",
  ],
  "exclude": ["node_modules", "dist"]
}
